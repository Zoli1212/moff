{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "bash .claude/qa/post-commit-trigger.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
